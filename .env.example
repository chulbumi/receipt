# ============================================================
# 영수증 관리 시스템 - 환경변수 설정 예시
# 이 파일을 복사하여 .env 로 저장하고 실제 값을 입력하세요
# cp .env.example .env
# ============================================================

# ----- AWS 설정 -----
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=CHANGE_ME_YOUR_AWS_ACCOUNT_ID

# ----- S3 버킷 이름 -----
S3_IMAGES_BUCKET=receipt-images-CHANGE_ME_ACCOUNT_ID
S3_FRONTEND_BUCKET=receipt-frontend-CHANGE_ME_ACCOUNT_ID

# ----- DynamoDB 테이블 이름 -----
DYNAMODB_USERS_TABLE=receipt_users
DYNAMODB_RECORDS_TABLE=receipt_records
DYNAMODB_CARDS_TABLE=receipt_cards

# ----- JWT 인증 설정 -----
# 아래 명령으로 랜덤 시크릿 생성: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# ----- Google Gemini API -----
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash-lite

# ----- 초기 관리자 계정 -----
ADMIN_USER_ID=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_NAME=시스템관리자

# ----- 프론트엔드 API URL (배포 후 API Gateway URL) -----
VITE_API_BASE_URL=https://CHANGE_ME.execute-api.ap-northeast-2.amazonaws.com/prod
VITE_APP_NAME=영수증 관리

# ----- 로컬 개발용 백엔드 포트 -----
BACKEND_PORT=8000
